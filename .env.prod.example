# ──────────────────────────────────────────────────────────────────────────────
# Orbis Outreach - BPS — Production Environment Template (.env.prod)
# ──────────────────────────────────────────────────────────────────────────────

# ── Server Ports
DASHBOARD_PORT=30000
MARKETING_PORT=20000
API_PORT=40000
WORKERS_PORT=44444

# ── Security
# IMPORTANT: Sensitive values (JWT, API keys, DB passwords) are now handled 
# via Docker Secrets in secrets/*.txt. See docs/DEPLOYMENT.md for setup.

# ── Monitoring (Optional)
# SENTRY_DSN=https://xxx@sentry.io/xxx
LOG_LEVEL=info

# ── Infrastructure Settings
NODE_ENV=production
