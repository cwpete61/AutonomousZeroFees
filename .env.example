# ─── General ────────────────────────────────────────────────────
NODE_ENV=development

# ─── Database ───────────────────────────────────────────────────
DATABASE_URL=postgresql://agency:agency@localhost:5432/agency?schema=core
POSTGRES_DB=agency
POSTGRES_USER=agency
POSTGRES_PASSWORD=agency

# ─── Redis ──────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth / Sessions ───────────────────────────────────────────
JWT_SECRET=change-me-in-production
SESSION_EXPIRY_HOURS=24

# ─── Email (Resend or SendGrid) ────────────────────────────────
RESEND_API_KEY=
SENDGRID_API_KEY=
EMAIL_FROM=agency@yourdomain.com

# ─── Payments (Stripe) ─────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ─── Object Storage (S3-compatible) ────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=agency-assets
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1

# ─── Monitoring ─────────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=debug

# ─── Antigravity Integration ───────────────────────────────────
ANTIGRAVITY_PROJECTS_PATH=
PROJECT_EXPORT_PATH=
BUILD_ARTIFACT_PATH=

# ─── Backup ─────────────────────────────────────────────────────
BACKUP_LOCAL_PATH=./backups
BACKUP_S3_BUCKET=agency-backups
BACKUP_RETENTION_DAILY=14
BACKUP_RETENTION_WEEKLY=8
BACKUP_RETENTION_MONTHLY=12

# ─── Dashboard ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
DASHBOARD_PORT=3000
API_PORT=4000
WORKERS_PORT=4001

# ─── OpenCode Configuration ─────────────────────────────────────
OPENCODE_DIR=C:\Users\crawf\AppData\Local\OpenCode
OPENCODE_CONFIG_DIR=C:\Users\crawf\AppData\Local\OpenCode
